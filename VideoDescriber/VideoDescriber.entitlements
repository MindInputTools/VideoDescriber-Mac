<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow screen recording via ScreenCaptureKit -->
    <key>com.apple.security.screen-recording</key>
    <true/>

    <!-- Allow outgoing network connections (to localhost Ollama) -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- App Sandbox must be enabled for Mac App Store,
         but can be disabled for direct distribution if needed -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
